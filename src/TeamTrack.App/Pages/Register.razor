@page "/register"
@layout AuthLayout

@inject NavigationManager Nav
@inject IAuthService AuthService
@inject ISnackbar Snackbar

<div class="register-container">

    <!-- LEFT BLUE SECTION -->
    <div class="left-section">

        <!-- Top heading -->
        <div class="left-header">
            <h1 class="welcome-title">Welcome to TeamTrack</h1>
        </div>

        <!-- Center block -->
        <div class="left-center">
            <h2 class="big-title">Get Started</h2>
            <p class="small-text">Already have an account?</p>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       Class="big-btn"
                       OnClick="@(() => Nav.NavigateTo("/login"))">
                LOGIN
            </MudButton>
        </div>

        <div class="pattern-overlay"></div>
    </div>

    <!-- RIGHT REGISTRATION PANEL -->
    <div class="right-section">

        <MudPaper Class="register-card" Elevation="6">

            <MudText Typo="Typo.h4" Class="form-title">
                Create Account
            </MudText>

            <MudForm @ref="_form" Valid="@_isValid">

                <MudTextField @bind-Value="_model.FirstName"
                              Label="First Name"
                              Required="true"
                              Class="mb-3" />

                <MudTextField @bind-Value="_model.LastName"
                              Label="Last Name"
                              Required="true"
                              Class="mb-3" />

                <MudTextField @bind-Value="_model.Email"
                              Label="Email"
                              Required="true"
                              InputType="InputType.Email"
                              Class="mb-3" />

                <MudTextField @bind-Value="_model.Password"
                              Label="Password"
                              Required="true"
                              InputType="InputType.Password"
                              Class="mb-4" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Loading="_loading"
                           Disabled="_loading"
                           Class="signup-btn"
                           OnClick="RegisterAsync">
                    Create Account
                </MudButton>

            </MudForm>

            <MudText Class="small-terms mt-3 text-center">
                By signing up, you agree to our Privacy Policy & Terms.
            </MudText>

        </MudPaper>

    </div>

</div>

<style>

    /* MAIN GRID */
    .register-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        height: 100vh;
        overflow: hidden;
    }

    /* LEFT SECTION */

    .left-section {
        background: #0046FF;
        position: relative;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }


    .left-header {
        margin-top: 0.5rem;
    }


    .welcome-title {
        color: white;
        font-size: 2.6rem;
        font-weight: 700;
        margin-top: 0.4rem;
        margin-left: 0.5rem;
        font-family: "Segoe UI", sans-serif;
    }


    .left-center {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);

        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 0.7rem;
    }



    .big-title {
        font-size: 2.4rem;
        font-weight: 700;
        color: white;
    }

    .small-text {
        color: rgba(255,255,255,0.85);
        font-size: 0.95rem;
    }



    .big-btn {
        border: 2px solid rgba(255,255,255,0.8) !important;
        color: white !important;
        padding: 0.85rem 2.5rem;
        font-size: 1.1rem;
        border-radius: 30px;
        font-weight: 600;
        background: transparent !important; /* ✅ ensure no fill */
        transition: 0.25s ease;
    }

        /* ✅ Glow effect ONLY on border, no background fill */
        .big-btn:hover {
            background: transparent !important;
            box-shadow: 0 0 12px rgba(255,255,255,0.8);
            border-color: white !important;
            transform: scale(1.03);
        }


    .pattern-overlay {
        position: absolute;
        inset: 0;
        background-image: url("images/pattern-waves.svg");
        background-size: cover;
        background-position: center;
        opacity: 0.25;
        pointer-events: none;
    }

    /* RIGHT PANEL */
    .right-section {
        background: #F5F6FA;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 1rem;
    }

    .register-card {
        width: 100%;
        max-width: 420px;
        padding: 2.5rem;
        border-radius: 18px;
        background: white;
    }

    .form-title {
        font-weight: 700;
        margin-bottom: 1.5rem;
        text-align: center;
    }

    .signup-btn {
        padding: 0.75rem 0;
        font-weight: 600;
        border-radius: 10px;
    }

    .small-terms {
        font-size: 0.85rem;
        color: #777;
    }

</style>

@code {
    private MudForm? _form;
    private bool _isValid;
    private bool _loading;

    private RegisterDto _model = new();

    private async Task RegisterAsync()
    {
        await _form!.ValidateAsync();

        if (!_form.IsValid)
            return;

        _loading = true;

        var result = await AuthService.RegisterAsync(_model);
        _loading = false;

        if (result.Success)
        {
            Snackbar.Add("Registration successful!", Severity.Success);
            Nav.NavigateTo("/login");
        }

        else
        {
            var errorMessage =
                result.Message ??
                (result.Errors != null && result.Errors.Any() ? result.Errors.First() : null) ??
                "Registration failed. Please try again.";

            Snackbar.Add(errorMessage, Severity.Error);
        }

    }
}
