@page "/dashboard"
@layout ApplicationLayout
@inherits BasePageComponent

@if (IsLoading)
{ <MudContainer MaxWidth="MaxWidth.Large" Class="mt-6 px-4 px-md-8"> <MudSkeleton Type="SkeletonType.Text" Width="300px" Height="40px" Class="mb-6" /> <MudGrid Spacing="3">
@for (int i = 0; i < 6; i++)
{ <MudItem xs="12" sm="6" md="4" lg="3"> <MudSkeleton Type="SkeletonType.Rectangle" Height="138px" Class="rounded-xl" /> </MudItem>
} </MudGrid>


    <MudGrid Spacing="3" Class="mt-8">
        <MudItem xs="12" md="4">
            <MudSkeleton Height="280px" Class="rounded-xl" />
        </MudItem>
        <MudItem xs="12" md="8">
            <MudSkeleton Height="280px" Class="rounded-xl" />
        </MudItem>
    </MudGrid>
</MudContainer>


}
else
{ <MudContainer MaxWidth="MaxWidth.Large" Class="mt-6 px-4 px-md-8">


    <!-- Welcome -->
    <MudText Typo="Typo.h4" Class="mb-1 font-weight-bold">
        Welcome back, @_userFirstName!
    </MudText>

    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-8">
        Here's what's happening across your organizations
    </MudText>

    <!-- Stats -->
    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="4" lg="3">
            <StatCard Icon="@Icons.Material.Filled.Folder" Title="Total Projects" Value="@_stats?.TotalProjects" Color="Color.Primary" />
        </MudItem>
        <MudItem xs="12" sm="6" md="4" lg="3">
            <StatCard Icon="@Icons.Material.Filled.Assignment" Title="Total Tasks" Value="@_stats?.TotalTasks" Color="Color.Info" />
        </MudItem>
        <MudItem xs="12" sm="6" md="4" lg="3">
            <StatCard Icon="@Icons.Material.Filled.CheckCircle" Title="Completed" Value="@_stats?.CompletedTasks" Color="Color.Success" />
        </MudItem>
        <MudItem xs="12" sm="6" md="4" lg="3">
            <StatCard Icon="@Icons.Material.Filled.WarningAmber" Title="Overdue" Value="@_stats?.OverdueTasks" Color="Color.Error" />
        </MudItem>
        <MudItem xs="12" sm="6" md="4" lg="3">
            <StatCard Icon="@Icons.Material.Filled.People" Title="Team Members" Value="@_stats?.TeamMembers" Color="Color.Secondary" />
        </MudItem>
        <MudItem xs="12" sm="6" md="4" lg="3">
            <StatCard Icon="@Icons.Material.Filled.Notifications" Title="Unread" Value="@_stats?.UnreadNotifications" Color="Color.Warning" />
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="3" Class="mt-8">

        <!-- Quick Actions -->
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-6 rounded-xl h-100">
                <MudText Typo="Typo.h6" Class="mb-5">Quick Actions</MudText>

                <MudStack Spacing="3">
                    <MudButton FullWidth Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.AddTask"
                               OnClick='() => Nav.NavigateTo("/tasks/create")'>
                        New Task
                    </MudButton>

                    <MudButton FullWidth Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Folder"
                               OnClick='() => Nav.NavigateTo("/projects")'>
                        New Project
                    </MudButton>

                    <MudButton FullWidth Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.GroupAdd"
                               OnClick='() => Nav.NavigateTo("/admin/invite")'
                               Disabled="@(!_isAdmin)">
                        Invite Member
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>

        <!-- Recent Tasks -->
        <MudItem xs="12" md="8">
            <MudPaper Elevation="2" Class="pa-6 rounded-xl">

                <div class="d-flex justify-space-between align-center mb-4">
                    <MudText Typo="Typo.h6">Recent Tasks</MudText>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/tasks">
                        View All
                    </MudButton>
                </div>

                @if (_recentTasks?.Any() == true)
                {
                    <MudTable Items="_recentTasks" Dense Hover>

                        <HeaderContent>
                            <MudTh>Title</MudTh>
                            <MudTh>Project</MudTh>
                            <MudTh>Priority</MudTh>
                            <MudTh>Due Date</MudTh>
                            <MudTh>Status</MudTh>
                        </HeaderContent>

                        <RowTemplate Context="task">
                            <MudTd Style="cursor:pointer;" @onclick="() => OpenTaskDetail(task.Id)">
                                <strong>@task.Title</strong>
                            </MudTd>

                            <MudTd>@(task.ProjectName ?? "—")</MudTd>

                            <MudTd>
                                <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(task.Priority)">
                                    @task.Priority
                                </MudChip>
                            </MudTd>

                            <MudTd>
                                @if (task.DueDate.HasValue)
                                {
                                    bool overdue = task.DueDate < DateTimeOffset.UtcNow && task.Status != "Done";
                                    <span class="@(overdue ? "text-error font-weight-medium" : "")">
                                        @task.DueDate.Value.ToString("dd MMM yyyy")
                                    </span>
                                }
                                else
                                {
                                    <span>—</span>
                                }
                            </MudTd>

                            <MudTd>
                                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(task.Status)">
                                    @task.Status
                                </MudChip>
                            </MudTd>
                        </RowTemplate>

                    </MudTable>
                }
                else
                {
                    <MudText Align="Align.Center" Color="Color.Secondary" Class="py-10">
                        No recent tasks found
                    </MudText>
                }

            </MudPaper>
        </MudItem>

        <!-- Project Progress -->
        <MudItem xs="12" Class="mt-4">
            <MudPaper Elevation="2" Class="pa-6 rounded-xl">

                <MudText Typo="Typo.h6" Class="mb-5">Project Progress</MudText>

                @if (_projectProgress?.Any() == true)
                {
                    <MudGrid Spacing="4">
                        @foreach (var proj in _projectProgress)
                        {
                            <MudItem xs="12" sm="6" md="4">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudText Typo="Typo.subtitle1">@proj.Name</MudText>

                                        <MudProgressLinear Color="Color.Success"
                                                           Value="@proj.ProgressPercent"
                                                           Class="my-3" />

                                        <div class="d-flex justify-space-between">
                                            <MudText Typo="Typo.body2">
                                                @proj.CompletedTasks / @proj.TotalTasks tasks
                                            </MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Success">
                                                @proj.ProgressPercent%
                                            </MudText>
                                        </div>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                        }
                    </MudGrid>
                }
                else
                {
                    <MudText Color="Color.Secondary">No projects found</MudText>
                }

            </MudPaper>
        </MudItem>

    </MudGrid>
</MudContainer>


}

@code {


private DashboardStats? _stats;
private List<RecentTaskItem>? _recentTasks;
private List<ProjectProgressItem>? _projectProgress;

private string? _userFirstName;
private bool _isAdmin;

[Inject] private IDashboardService DashboardService { get; set; } = default!;
[Inject] private ILocalStorageService Storage { get; set; } = default!;

protected override async Task OnInitializedAsync()
{
    await ExecuteSafeAsync(async () =>
    {
        var login = await Storage.GetItemAsync<LoginResponseDto>("loginResponse");

        _userFirstName = login?.User?.FirstName ?? "User";

        _isAdmin = login?.User?.Roles?
            .Any(r => r.Contains("Admin", StringComparison.OrdinalIgnoreCase)) == true;

        var response = await DashboardService.GetDashboardAsync();

        if (response == null || !response.Success || response.Data == null)
        {
            Snackbar.Add(response?.Message ?? "Failed to load dashboard", Severity.Warning);
            return;
        }

        _stats = response.Data.Stats;
        _recentTasks = response.Data.RecentTasks;
        _projectProgress = response.Data.ProjectProgress;

    }, "Error loading dashboard");
}

private void OpenTaskDetail(Guid taskId)
{
    Nav.NavigateTo($"/tasks/{taskId}");
}

private Color GetStatusColor(string? status) => status?.ToLowerInvariant() switch
{
    "done" => Color.Success,
    "in progress" => Color.Info,
    "review" => Color.Warning,
    "todo" => Color.Default,
    _ => Color.Secondary
};

private Color GetPriorityColor(string? priority) => priority?.ToLowerInvariant() switch
{
    "high" => Color.Error,
    "medium" => Color.Warning,
    "low" => Color.Info,
    _ => Color.Default
};


}
